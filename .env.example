NODE_ENV=development

POSTGRES_DB=hubcontabil
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://USER:PASSWORD@POSTGRES_HOST:5432/hubcontabil?schema=public

REDIS_HOST=REDIS_HOST
REDIS_PORT=6379

JWT_SECRET=change-me-in-local-env
JWT_EXPIRES_IN=1d

API_PORT=3333
API_URL=http://localhost:7001
NEXT_PUBLIC_API_URL=http://localhost:7001/api

STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=20

RESEND_API_KEY=
RESEND_FROM_NAME=Equipe do escritório
RESEND_FROM_EMAIL=contato@example.com

WPPCONNECT_BASE_URL=http://WPPCONNECT_HOST:21465
WPPCONNECT_TOKEN=
WPPCONNECT_SESSION=hubcontabil
WPPCONNECT_SEND_FILE_PATH=/api/{session}/send-file-base64

OFFICE_NAME=HubContabil
