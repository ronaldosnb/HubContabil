generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COLLABORATOR
}

enum ClientType {
  INDIVIDUAL
  COMPANY
  MEI
  RURAL_PRODUCER
  OTHER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  SUSPENDED
}

enum PreferredChannel {
  EMAIL
  WHATSAPP
  BOTH
}

enum DocumentStatus {
  PENDING
  SENT
  PAID
  OVERDUE
  CANCELED
}

enum DocumentSendStatus {
  PENDING
  PROCESSING
  SENT
  PARTIAL_ERROR
  ERROR
  CANCELED
}

enum SendChannel {
  EMAIL
  WHATSAPP
}

enum SendChannelStatus {
  PENDING
  SENT
  ERROR
  RETRYING
  CANCELED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING_CLIENT
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id                    String         @id @default(uuid())
  name                  String
  email                 String         @unique
  passwordHash          String
  role                  UserRole       @default(COLLABORATOR)
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  responsibleClients    Client[]       @relation("ClientResponsible")
  uploadedDocuments     Document[]     @relation("DocumentUploader")
  createdSends          DocumentSend[] @relation("DocumentSendCreator")
  reviewedSends         DocumentSend[] @relation("DocumentSendReviewer")
  responsibleTasks      Task[]         @relation("TaskResponsible")
  createdTasks          Task[]         @relation("TaskCreator")
  responsibleRecurrences RecurringTask[] @relation("RecurringTaskResponsible")
  activityLogs          ActivityLog[]
}

model Client {
  id                    String         @id @default(uuid())
  type                  ClientType
  name                  String
  legalName             String?
  documentNumber        String?
  taxRegime             String?
  status                ClientStatus   @default(ACTIVE)
  internalResponsibleId String?
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  internalResponsible   User?          @relation("ClientResponsible", fields: [internalResponsibleId], references: [id])
  contacts              ClientContact[]
  services              ClientService[]
  documents             Document[]
  documentSends         DocumentSend[]
  tasks                 Task[]
  recurringTasks        RecurringTask[]
  activityLogs          ActivityLog[]

  @@index([name])
  @@index([documentNumber])
  @@index([status])
}

model ClientContact {
  id               String           @id @default(uuid())
  clientId         String
  name             String
  roleDescription  String?
  email            String?
  phone            String?
  whatsapp         String?
  isMain           Boolean          @default(false)
  preferredChannel PreferredChannel @default(EMAIL)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  client           Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Service {
  id          String          @id @default(uuid())
  name        String          @unique
  description String?
  isActive    Boolean         @default(true)
  clients     ClientService[]
}

model ClientService {
  id        String   @id @default(uuid())
  clientId  String
  serviceId String
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id])

  @@unique([clientId, serviceId])
  @@index([clientId])
}

model Department {
  id             String          @id @default(uuid())
  name           String          @unique
  description    String?
  isActive       Boolean         @default(true)
  tasks          Task[]
  recurringTasks RecurringTask[]
}

model Document {
  id               String         @id @default(uuid())
  clientId         String
  uploadedByUserId String
  category         String
  title            String
  description      String?
  originalFileName String
  storedFileName   String
  storagePath      String
  mimeType         String
  size             Int
  competence       String?
  dueDate          DateTime?
  amount           Decimal?       @db.Decimal(12, 2)
  status           DocumentStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  client           Client         @relation(fields: [clientId], references: [id])
  uploadedBy       User           @relation("DocumentUploader", fields: [uploadedByUserId], references: [id])
  sends            DocumentSend[]
  tasks            Task[]

  @@index([clientId])
  @@index([category])
  @@index([status])
  @@index([dueDate])
}

model DocumentSend {
  id               String             @id @default(uuid())
  documentId       String
  clientId         String
  createdByUserId  String
  reviewedByUserId String?
  messageSubject   String?
  messageBody      String
  sendEmail        Boolean            @default(false)
  sendWhatsapp     Boolean            @default(false)
  status           DocumentSendStatus @default(PENDING)
  createdAt        DateTime           @default(now())
  sentAt           DateTime?
  updatedAt        DateTime           @updatedAt

  document         Document           @relation(fields: [documentId], references: [id])
  client           Client             @relation(fields: [clientId], references: [id])
  createdBy        User               @relation("DocumentSendCreator", fields: [createdByUserId], references: [id])
  reviewedBy       User?              @relation("DocumentSendReviewer", fields: [reviewedByUserId], references: [id])
  channels         DocumentSendChannel[]
  tasks            Task[]

  @@index([clientId])
  @@index([documentId])
  @@index([status])
}

model DocumentSendChannel {
  id                  String            @id @default(uuid())
  documentSendId      String
  channel             SendChannel
  recipientName       String?
  recipientEmail      String?
  recipientWhatsapp   String?
  status              SendChannelStatus @default(PENDING)
  providerMessageId   String?
  errorMessage        String?
  sentAt              DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  documentSend        DocumentSend      @relation(fields: [documentSendId], references: [id], onDelete: Cascade)

  @@index([documentSendId])
  @@index([channel])
  @@index([status])
}

model Task {
  id                  String       @id @default(uuid())
  clientId            String?
  title               String
  description         String?
  departmentId        String?
  responsibleUserId   String?
  createdByUserId     String
  documentId          String?
  documentSendId      String?
  status              TaskStatus   @default(TODO)
  priority            TaskPriority @default(MEDIUM)
  dueDate             DateTime?
  completedAt         DateTime?
  isRecurringInstance Boolean      @default(false)
  recurringTaskId     String?
  replicatedFromTaskId String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  client              Client?      @relation(fields: [clientId], references: [id])
  department          Department?  @relation(fields: [departmentId], references: [id])
  responsibleUser     User?        @relation("TaskResponsible", fields: [responsibleUserId], references: [id])
  createdBy           User         @relation("TaskCreator", fields: [createdByUserId], references: [id])
  document            Document?    @relation(fields: [documentId], references: [id])
  documentSend        DocumentSend? @relation(fields: [documentSendId], references: [id])
  recurringTask       RecurringTask? @relation(fields: [recurringTaskId], references: [id])
  replicatedFromTask  Task?        @relation("ReplicatedTasks", fields: [replicatedFromTaskId], references: [id])
  replicas            Task[]       @relation("ReplicatedTasks")

  @@index([clientId])
  @@index([departmentId])
  @@index([responsibleUserId])
  @@index([status])
  @@index([dueDate])
}

model RecurringTask {
  id                String   @id @default(uuid())
  title             String
  description       String?
  clientId          String?
  departmentId      String?
  responsibleUserId String?
  recurrenceRule    String
  nextRunAt         DateTime
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client            Client?     @relation(fields: [clientId], references: [id])
  department        Department? @relation(fields: [departmentId], references: [id])
  responsibleUser   User?       @relation("RecurringTaskResponsible", fields: [responsibleUserId], references: [id])
  tasks             Task[]

  @@index([nextRunAt])
  @@index([isActive])
}

model ActivityLog {
  id          String   @id @default(uuid())
  clientId    String?
  userId      String?
  entityType  String
  entityId    String
  action      String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  client      Client?  @relation(fields: [clientId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([userId])
  @@index([entityType, entityId])
}

model SystemSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
